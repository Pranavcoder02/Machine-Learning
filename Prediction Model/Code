import numpy as np

import pandas as pd

df = pd.read_csv('/content/placement.csv')
df.head()

## Steps to Make ML Model
# Preprocess + EDA(Exploratiory Data Analysis) + Feature Selection.
# Extract INput and Output Cols
# Scale the values
# Train test split
# Train the Model
# Evaluate the Model Selection
# Deploy The Model.

df.info() # Function Explain Everything About Cols Which is Present in Dataset

df.iloc[:,1:] # Contains all rows and all cols after first.
df.head()

# EDA (Exploratiory Data Analysis)

import matplotlib.pyplot as plt
plt.scatter(df['cgpa'],df['iq'],c=df['placement'])

# Yellow Points indicates placed studetns.

# Extract Input & Output Cols
x = df.iloc[:,0:2]
y = df.iloc[:,-1]

x # Showing X axis having CGPA & IQ cols

y # Showing y axis having Placement cols

## Train test split

from sklearn.model_selection import train_test_split
x_train,x_test,y_train,y_test = train_test_split(x,y,test_size=0.1)

x_train

from sklearn.preprocessing import StandardScaler #This is class

scalar = StandardScaler() #Object for this class.

x_train = scalar.fit_transform(x_train)

x_train

x_test = scalar.transform(x_test)

x_test

# In Above Case we completed Testing Part
# Now we move toward the Model Training Part.
from sklearn.linear_model import LogisticRegression

obj = LogisticRegression()

# This is Model Training.
obj.fit(x_train,y_train) # Fit() is used to train the model and it pass traing parameter like x_train & y_train

# Evaluate the Model Selection testing on unknown Data
y_predict = obj.predict(x_test)
y_predict
y_test

# To Calculate accuracy score my model prediction and Actual Output use this function
from sklearn.metrics import accuracy_score
acuracy_score = accuracy_score(y_test,y_predict)
acuracy_score

# Using This Function We can Plot Decision Boundary Over model Data
from mlxtend.plotting  import plot_decision_regions # Function

plot_decision_regions(x_train,y_train.values, clf = obj, legend = 2)

import pickle

pickle.dump(obj,open('model.pkl','wb'))
